<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="start_server"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_server"
        android:shortcutShortLabel="@string/shortcut_start_server_short"
        android:shortcutLongLabel="@string/shortcut_start_server_long">
        <intent
            android:action="com.cuscus.wifiaudiostreaming.START_SERVER"
            android:targetPackage="com.cuscus.wifiaudiostreaming"
            android:targetClass="com.cuscus.wifiaudiostreaming.MainActivity" />
    </shortcut>

    <shortcut
        android:shortcutId="stop_streaming"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_stop"
        android:shortcutShortLabel="@string/shortcut_stop_short"
        android:shortcutLongLabel="@string/shortcut_stop_long">
        <intent
            android:action="com.cuscus.wifiaudiostreaming.STOP_STREAMING"
            android:targetPackage="com.cuscus.wifiaudiostreaming"
            android:targetClass="com.cuscus.wifiaudiostreaming.MainActivity" />
    </shortcut>

</shortcuts>